# KitaMo Android — environment template
#
# Copy this file to `.env` (which is gitignored) and fill in values ONLY when
# you want to enable the optional Supabase cloud layer. The app runs fully
# local-first with these left blank — no cloud, no network calls.

# Public Supabase project URL (safe to expose in a mobile app).
EXPO_PUBLIC_SUPABASE_URL=

# Public Supabase anon key (safe to expose ONLY with proper Row Level Security).
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Notes:
# - Do NOT commit your real `.env` file.
# - NEVER put a Supabase service-role key in this mobile app — it bypasses RLS
#   and would expose all data. Service-role keys belong only on a trusted server.
# - The anon key is acceptable in the app only once RLS policies are in place
#   (planned in docs/supabase/rls-plan.md). Cloud sync is not implemented yet.
